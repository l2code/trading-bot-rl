# Copy to .env and fill in. Never commit .env.
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Live keys MUST be different from paper keys. Default behavior is paper-only.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# WRDS — uses ~/.pgpass for the password by default (see analysis/data/wrds_loader.py
# in trading-bot2 for reference; we read from cache/wrds/*.parquet).
WRDS_USERNAME=
WRDS_CACHE_DIR=

# Notifications
DISCORD_WEBHOOK_URL=

# Storage
RL_SWING_DATABASE_URL=sqlite:///data/cache/rl_swing.sqlite
