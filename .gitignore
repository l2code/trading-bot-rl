# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.so
.venv/
venv/
env/
# IMPORTANT: ``env/`` above is meant for virtualenv folders, but we
# also have a real Python package at ``src/rl_swing/rl/env/``. Re-
# include it explicitly so git tracks it.
!src/rl_swing/rl/env/
!src/rl_swing/rl/env/**

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Project data — large/ephemeral
data/cache/**
data/models/**
data/reports/**
!data/cache/.gitkeep
!data/models/.gitkeep
!data/reports/.gitkeep
*.parquet
*.duckdb
*.sqlite
*.sqlite-journal

# Logs / runs
logs/
runs/
tb_logs/
mlruns/

# Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Notebooks scratch
.ipynb_checkpoints/

# Colab artifacts
gdrive/

# Kaggle per-run materialized kernel dirs (re-created by scripts/kaggle_run.py)
data/kaggle/

# Cache dirs we don't want to track
**/__pycache__/
